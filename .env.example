# ============================================================================
# novel-to-movie configuration
# Copy this file to `.env` and fill in the keys.  All keys are server-side
# only and are read exclusively through config.py.  They are NEVER sent to
# the browser or referenced in client code.
# ============================================================================

# --- Operator-funded keys, server-side only -------------------------------
# Only the key for your selected LLM_PROVIDER is required (plus the aggregator
# and TTS keys). Leave the others blank.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
AGGREGATOR_API_KEY=
ELEVENLABS_API_KEY=

# --- Provider selection, swappable adapters -------------------------------
# LLM_PROVIDER: anthropic | gemini | openai
LLM_PROVIDER=anthropic
IMAGE_PROVIDER=aggregator
VIDEO_PROVIDER=aggregator
TTS_PROVIDER=elevenlabs
MUSIC_PROVIDER=aggregator

# Which aggregator to use for image/video/music adapters: fal or replicate
AGGREGATOR=fal

# --- Model identifiers, confirm against current provider docs -------------
# Keep these configurable; the market leaders shift every few months.
# Match LLM_MODEL to LLM_PROVIDER, e.g.:
#   anthropic -> claude-sonnet-4-6
#   gemini    -> gemini-2.0-flash
#   openai    -> gpt-4o
LLM_MODEL=claude-sonnet-4-6
# Optional: point the OpenAI adapter at a compatible gateway (Azure/OpenRouter/local)
# OPENAI_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=fal-ai/flux/dev
VIDEO_MODEL=fal-ai/kling-video/v1/standard/image-to-video
MUSIC_MODEL=fal-ai/stable-audio
# Max seconds of music to request (Stable Audio caps at ~47s); the track is
# looped to fill the movie. Set 0 to request the full movie length.
MUSIC_MAX_SECONDS=47
# Default loudness of the music bed under the narration (0.0 = silent,
# 1.0 = full). Visitors can override this per job from the UI.
MUSIC_VOLUME=0.28
TTS_VOICE_ID=narrator-default

# --- Movie shape ----------------------------------------------------------
TARGET_DURATION_SECONDS=120
SHOT_COUNT=15
SHOT_LENGTH_SECONDS=8

# --- Automation and cost guardrails ---------------------------------------
MAX_RETRIES_PER_SHOT=2
MAX_MOVIES_PER_SESSION=1
FAILED_SHOT_FALLBACK=hold_still     # hold_still or drop_shot
SESSION_TTL_MINUTES=60
MAX_UPLOAD_MB=25

# --- Runtime --------------------------------------------------------------
RUN_MODE=real                       # real or mock
PORT=8000
HOST=0.0.0.0
